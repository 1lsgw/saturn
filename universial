-- ══════════════════════════════════════════════════
--  FLY
-- ══════════════════════════════════════════════════

local function startFly()
    local char = LocalPlayer.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return end
    flying = true
    flyBV = Instance.new("BodyVelocity", char.HumanoidRootPart)
    flyBV.MaxForce = Vector3.new(1e6, 1e6, 1e6); flyBV.Velocity = Vector3.zero
    flyBG = Instance.new("BodyGyro", char.HumanoidRootPart)
    flyBG.MaxTorque = Vector3.new(1e6, 1e6, 1e6); flyBG.D = 200; flyBG.P = 1e4
    spawn(function()
        while flying and flyBV and flyBV.Parent do
            local cam = workspace.CurrentCamera; local dir = Vector3.zero
            if UserInputService:IsKeyDown(Enum.KeyCode.W) then dir = dir + cam.CFrame.LookVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.S) then dir = dir - cam.CFrame.LookVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.A) then dir = dir - cam.CFrame.RightVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.D) then dir = dir + cam.CFrame.RightVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.Space) then dir = dir + Vector3.yAxis end
            if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then dir = dir - Vector3.yAxis end
            if dir.Magnitude > 0 then dir = dir.Unit end
            flyBV.Velocity = dir * (sliderValues["Fly Speed"] or 100)
            flyBG.CFrame = cam.CFrame; RunService.RenderStepped:Wait()
        end
    end)
end

local function stopFly()
    flying = false
    if flyBV then flyBV:Destroy(); flyBV = nil end
    if flyBG then flyBG:Destroy(); flyBG = nil end
end

