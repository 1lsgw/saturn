--  ESP
-- ══════════════════════════════════════════════════

local espHolder = Instance.new("Folder")
espHolder.Name = "ESP"
espHolder.Parent = LocalPlayer.PlayerGui
local espCache = {}

local function makeESP(player)
    if player == LocalPlayer then return end
    local folder = Instance.new("Folder", espHolder); folder.Name = player.Name
    local bb = Instance.new("BillboardGui", folder)
    bb.Size = UDim2.new(0, 200, 0, 50); bb.StudsOffset = Vector3.new(0, 3.5, 0); bb.AlwaysOnTop = true
    local nameL = Instance.new("TextLabel", bb); nameL.Size = UDim2.new(1, 0, 0.5, 0)
    nameL.BackgroundTransparency = 1; nameL.TextColor3 = Color3.fromRGB(255, 120, 255)
    nameL.Font = Enum.Font.GothamBold; nameL.TextSize = 14; nameL.TextStrokeTransparency = 0.4
    nameL.Text = player.DisplayName
    local distL = Instance.new("TextLabel", bb); distL.Size = UDim2.new(1, 0, 0.5, 0)
    distL.Position = UDim2.new(0, 0, 0.5, 0); distL.BackgroundTransparency = 1
    distL.TextColor3 = Color3.fromRGB(200, 200, 255); distL.Font = Enum.Font.Gotham; distL.TextSize = 12
    local hl = Instance.new("Highlight", folder)
    hl.FillTransparency = 0.7; hl.OutlineTransparency = 0.1
    hl.OutlineColor = Color3.fromRGB(180, 100, 255); hl.FillColor = Color3.fromRGB(130, 60, 255)
    espCache[player] = { folder = folder, bb = bb, nameL = nameL, distL = distL, hl = hl }
end

RunService.RenderStepped:Connect(function()
    for _, player in pairs(Players:GetPlayers()) do
        if player == LocalPlayer then continue end
        if not espCache[player] then makeESP(player) end
        local e = espCache[player]; local show = toggleStates["Player ESP"]
        local char = player.Character
        if show and char and char:FindFirstChild("HumanoidRootPart") then
            e.bb.Adornee = char:FindFirstChild("Head") or char.HumanoidRootPart
            e.bb.Enabled = true; e.hl.Adornee = char; e.hl.Enabled = true
            e.nameL.Visible = (toggleStates["ESP Names"] ~= false)
            if toggleStates["ESP Distance"] then
                local myC = LocalPlayer.Character
                if myC and myC:FindFirstChild("HumanoidRootPart") then
                    e.distL.Text = math.floor((myC.HumanoidRootPart.Position - char.HumanoidRootPart.Position).Magnitude) .. " studs"
                    e.distL.Visible = true
                end
            else e.distL.Visible = false end
            if toggleStates["ESP Health Color"] and char:FindFirstChildOfClass("Humanoid") then
                local hum = char:FindFirstChildOfClass("Humanoid")
                local pct = math.clamp(hum.Health / hum.MaxHealth, 0, 1)
                e.hl.FillColor = Color3.fromRGB(255 * (1 - pct), 255 * pct, 50)
                e.hl.OutlineColor = Color3.fromRGB(255 * (1 - pct), 255 * pct, 80)
            end
        else e.bb.Enabled = false; e.hl.Enabled = false end
    end
end)

Players.PlayerRemoving:Connect(function(p)
    if espCache[p] then espCache[p].folder:Destroy(); espCache[p] = nil end
end)

-- FPS
local fpsAccum, fpsCount = 0, 0
RunService.RenderStepped:Connect(function(dt)
    if toggleStates["Show FPS"] then
        fpsAccum = fpsAccum + dt
        fpsCount = fpsCount + 1
        if fpsAccum >= 1 then
            local fps = math.floor(fpsCount / fpsAccum)
            WindUI:Notify({ Title = "FPS", Content = tostring(fps) .. " fps", Icon = "activity", Duration = 1 })
            fpsAccum = 0; fpsCount = 0
        end
    end
end)

